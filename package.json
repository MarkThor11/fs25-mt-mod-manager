{
  "name": "fs25-mt-mod-manager",
  "version": "1.0.9",
  "description": "Farming Simulator 25 ModHub Desktop Manager",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "dist:win": "vite build && electron-builder --win",
    "dist:mac": "vite build && electron-builder --mac",
    "dist": "vite build && electron-builder --win --mac"
  },
  "author": "GoogleModManager",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "icon-gen": "^5.0.0",
    "png-to-ico": "^3.0.1",
    "vite": "^5.2.11",
    "vite-plugin-javascript-obfuscator": "^3.1.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.12",
    "better-sqlite3": "^11.0.0",
    "cheerio": "^1.0.0-rc.12",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "fast-xml-parser": "^5.7.1",
    "fs-extra": "^11.2.0",
    "lucide-react": "^0.378.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "zustand": "^4.5.2"
  },
  "build": {
    "appId": "com.fs25.modhub-manager",
    "productName": "FS25 MT Mod Manager",
    "artifactName": "FS25-MT-Mod-Manager-Setup-${version}.${ext}",
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "MarkThor11",
        "repo": "fs25-mt-mod-manager-updates"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/main/resources/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png",
      "category": "public.app-category.utilities",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "FS25 MT Mod Manager",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "guid": "FS25-MT-MOD-MANAGER-NSIS-GUID",
      "include": "build/installer.nsh"
    }
  }
}
